# Backend environment template (do not commit real values)

# Runtime profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# Database
DB_URL=jdbc:mysql://localhost:3306/doan_ltmmt?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=change-me

# JWT (base64-encoded secret, at least 32 bytes raw key)
JWT_SECRET=change-me-base64-secret
JWT_EXPIRATION=86400000

# App toggles
APP_SEED_ENABLED=true
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.local
MAIL_PASSWORD=change-me
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true